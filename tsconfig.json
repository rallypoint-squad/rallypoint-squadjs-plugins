{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmit": true,
    "paths": {
      "core/*": ["./mocks/core/*.js"],
    },
    "rootDirs": [
      // "./mocks",
      "./mocks/plugins",
      "./plugins",
    ],
    "skipLibCheck": true,
    "types": [
      "vitest/globals"
    ],
    "target": "ES2022",
  },
  "exclude": ["node_modules"],
}
